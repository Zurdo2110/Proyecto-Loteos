<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Ingreso - Portal de Agrimensura</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light d-flex align-items-center" style="height: 100vh;">

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-sm border-0">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <img src="/images/logoEstudio.jpeg" alt="Buffarini & Asociados - Estudio de Agrimensura" style="width: 100%; max-width: 260px; height: auto;" class="mb-3">
                        <h3 class="text-primary fw-bold"> Portal de Clientes</h3>
                        <p class="text-muted">Ingrese sus credenciales</p>
                    </div>

                    {{#error}}
                        <div class="alert alert-danger p-2 text-center">{{error}}</div>
                    {{/error}}
                    {{#mensaje}}
                        <div class="alert alert-success p-2 text-center">{{mensaje}}</div>
                    {{/mensaje}}

                    <form action="/login" method="post">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Usuario</label>
                            <input type="text" name="username" class="form-control" required autofocus>
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-bold">Contraseña</label>
                            <input type="password" name="password" class="form-control" required>
                        </div>
                        
                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg fw-bold">Ingresar al Sistema</button>
                        </div>
                    </form>
                    
                </div>
            </div>
        </div>
    </div>
</div>

</body>
</html>