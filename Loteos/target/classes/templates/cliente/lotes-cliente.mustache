<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Portal de Clientes - {{loteo.nombre}}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

<div class="container-fluid px-4 mt-4">
    
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <div>
            <span class="text-muted text-uppercase fw-bold small">Portal de Clientes</span>
            <h2 class="mb-0 text-primary">🏗️ {{loteo.nombre}}</h2>
        </div>
        
        <div class="d-flex gap-2 align-items-center">
            {{#tieneEtapas}}
                {{#etapaSeleccionada}}
                    <a href="/cliente/loteos/{{loteo.idLoteo}}/visor?idEtapa={{etapaSeleccionada}}" class="btn btn-info text-white fw-bold">🗺️ Ver Plano</a>
                {{/etapaSeleccionada}}
            {{/tieneEtapas}}
            {{^tieneEtapas}}
                <a href="/cliente/loteos/{{loteo.idLoteo}}/visor" class="btn btn-info text-white fw-bold">🗺️ Ver Plano</a>
            {{/tieneEtapas}}
            
            <form action="/logout" method="post" class="m-0">
                <button type="submit" class="btn btn-outline-danger">Cerrar Sesión</button>
            </form>
        </div>
    </div>

    <div class="row">
        
        <div class="row justify-content-center">
        
        <div class="{{#loteSeleccionado}}col-md-4{{/loteSeleccionado}}{{^loteSeleccionado}}col-md-8{{/loteSeleccionado}} transition-all">
            
            {{#tieneEtapas}}
                <ul class="nav nav-tabs mb-3">
                    {{#etapas}}
                        <li class="nav-item">
                            <a class="nav-link fw-bold" href="/cliente/loteos/{{loteo.idLoteo}}/lotes?idEtapa={{idEtapa}}">📁 {{nombre}}</a>
                        </li>
                    {{/etapas}}
                </ul>
            {{/tieneEtapas}}

            <form action="/cliente/loteos/{{loteo.idLoteo}}/lotes" method="get" class="mb-3">
                <div class="input-group shadow-sm">
                    {{#etapaSeleccionada}}
                        <input type="hidden" name="idEtapa" value="{{etapaSeleccionada}}">
                    {{/etapaSeleccionada}}
                    <input type="text" name="buscar" class="form-control" placeholder="Buscar cuenta o titular..." value="{{#buscar}}{{buscar}}{{/buscar}}">
                    <button class="btn btn-primary" type="submit">🔍</button>
                    {{#buscar}}
                        <a href="/cliente/loteos/{{loteo.idLoteo}}/lotes" class="btn btn-outline-secondary">X</a>
                    {{/buscar}}
                </div>
            </form>

            <div class="list-group shadow-sm" style="max-height: 65vh; overflow-y: auto;">
                {{#lotes}}
                <a href="/cliente/loteos/{{loteo.idLoteo}}/lotes?idLoteSeleccionado={{idLote}}{{#etapaSeleccionada}}&idEtapa={{etapaSeleccionada}}{{/etapaSeleccionada}}{{#buscar}}&buscar={{buscar}}{{/buscar}}" 
                    class="list-group-item list-group-item-action py-2">
                    <div class="d-flex justify-content-between align-items-center">
                        <strong class="text-dark">Nro Cuenta: {{numeroCuenta}}</strong>
                    </div>
                    <small class="text-muted d-block text-truncate">Titular: {{#titular}}{{titular}}{{/titular}}{{^titular}}Sin asignar{{/titular}}</small>
                </a>
                {{/lotes}}
                
                {{^lotes}}
                <div class="alert alert-warning p-2 text-center text-muted small m-0">
                    No se encontraron parcelas.
                </div>
                {{/lotes}}
            </div>
        </div>

        {{#loteSeleccionado}}
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-body fs-6">
                    <div class="row mb-2">
                        <div class="col-sm-4 text-muted fw-bold">N° de Cuenta:</div>
                        <div class="col-sm-8 fs-5 text-dark fw-bold">{{numeroCuenta}}</div>
                    </div>
                    <hr class="my-2">
                    <div class="row mb-2">
                        <div class="col-sm-4 text-muted fw-bold">Nomenclatura:</div>
                        <div class="col-sm-8">{{#nomenclatura}}{{nomenclatura}}{{/nomenclatura}}{{^nomenclatura}}<span class="text-muted fst-italic">No cargada</span>{{/nomenclatura}}</div>
                    </div>
                    <hr class="my-2">
                    <div class="row mb-2">
                        <div class="col-sm-4 text-muted fw-bold">Titular:</div>
                        <div class="col-sm-8">{{#titular}}{{titular}}{{/titular}}{{^titular}}<span class="text-muted fst-italic">Sin asignar</span>{{/titular}}</div>
                    </div>
                    <hr class="my-2">
                    <div class="row mb-2">
                        <div class="col-sm-4 text-muted fw-bold">Designación Oficial:</div>
                        <div class="col-sm-8">{{#designacionOficial}}{{designacionOficial}}{{/designacionOficial}}{{^designacionOficial}}<span class="text-muted fst-italic">-</span>{{/designacionOficial}}</div>
                    </div>
                    <hr class="my-2">
                    <div class="row mb-2">
                        <div class="col-sm-4 text-muted fw-bold">Superficies (m²):</div>
                        <div class="col-sm-8">
                            <strong>Total:</strong> {{#superficie}}{{superficie}}{{/superficie}}{{^superficie}}0{{/superficie}} <br>
                            <strong>Cubierta:</strong> {{#superficieCubierta}}{{superficieCubierta}}{{/superficieCubierta}}{{^superficieCubierta}}0{{/superficieCubierta}}
                        </div>
                    </div>
                    <hr class="my-2">
                    <div class="row mb-2">
                        <div class="col-sm-4 text-muted fw-bold">Observaciones:</div>
                        <div class="col-sm-8">{{#observaciones}}{{observaciones}}{{/observaciones}}{{^observaciones}}<span class="text-muted fst-italic">Ninguna</span>{{/observaciones}}</div>
                    </div>
                </div>
                
                <div class="card-footer text-end bg-white d-flex justify-content-end gap-2 p-3">
                    <a href="/cliente/loteos/{{loteo.idLoteo}}/visor?cuenta={{numeroCuenta}}{{#etapaSeleccionada}}&idEtapa={{etapaSeleccionada}}{{/etapaSeleccionada}}" class="btn btn-info text-white fw-bold">🗺️ Mostrar en Mapa</a>
                    <a href="/cliente/lotes/{{idLote}}/editar" class="btn btn-warning fw-bold">Modificar Datos</a>
                </div>
            </div>
        </div>
        {{/loteSeleccionado}}

    </div>
</div>

</body>
</html>