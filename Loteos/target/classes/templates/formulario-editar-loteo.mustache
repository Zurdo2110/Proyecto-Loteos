<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Editar Proyecto</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card shadow">
                    <div class="card-header bg-warning text-dark">
                        <h4 class="mb-0">Modificar Nombre del Proyecto</h4>
                    </div>
                    <div class="card-body">
                        <form action="/loteos/{{loteo.idLoteo}}/editar" method="post">
                            <div class="mb-4">
                                <label for="nombre" class="form-label fw-bold">Nombre del Proyecto / Fideicomiso</label>
                                <input type="text" class="form-control" id="nombre" name="nombre" value="{{loteo.nombre}}" required>
                            </div>
                            <div class="d-flex justify-content-between">
                                <a href="/loteos/{{loteo.idLoteo}}/lotes" class="btn btn-outline-secondary">Cancelar</a>
                                <button type="submit" class="btn btn-warning fw-bold">Guardar Cambios</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>