<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Estudio de Agrimensura</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <nav class="navbar navbar-dark bg-dark mb-4">
        <div class="container">
            <span class="navbar-brand mb-0 h1">Sistema de Gestión Parcelaria</span>
        </div>
    </nav>

    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>Loteos Registrados</h2>
            <a href="/loteos/nuevo" class="btn btn-success">+ Nuevo Loteo</a>
        </div>
        
        <form action="/loteos" method="get" class="mb-4">
            <div class="input-group shadow-sm">
                <input type="text" name="buscar" class="form-control" placeholder="Buscar loteo por nombre..." value="{{#buscar}}{{buscar}}{{/buscar}}">
                <button class="btn btn-primary" type="submit">🔍 Buscar</button>
                {{#buscar}}
                    <a href="/loteos" class="btn btn-outline-secondary">Limpiar</a>
                {{/buscar}}
            </div>
        </form>
        
        <div class="list-group shadow-sm">
            {{#loteos}}
                <a href="/loteos/{{idLoteo}}/lotes" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center p-3">
                    <strong class="fs-5">{{nombre}}</strong>
                    <span class="badge bg-primary rounded-pill">Ver Lotes</span>
                </a>
            {{/loteos}}
            
            {{^loteos}}
                <div class="alert alert-warning text-center m-0">
                    Aún no hay loteos cargados en el sistema.
                </div>
            {{/loteos}}
        </div>
    </div>

</body>
</html>