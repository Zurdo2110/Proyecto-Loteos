<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Nueva Etapa</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">📁 Crear Nueva Etapa - {{loteo.nombre}}</h4>
                </div>
                <div class="card-body">
                    
                    <form action="/loteos/{{loteo.idLoteo}}/etapas/nueva" method="post">
                        
                        <div class="mb-3">
                            <label for="nombre" class="form-label fw-bold">Nombre de la Etapa</label>
                            <input type="text" class="form-control" id="nombre" name="nombre" 
                                   required placeholder="Ej: Primera Etapa, Sector Norte">
                        </div>

                        <div class="mb-4">
                            <label for="expedienteMunicipal" class="form-label fw-bold">Expediente Municipal (Opcional)</label>
                            <input type="text" class="form-control" id="expedienteMunicipal" name="expedienteMunicipal" 
                                   placeholder="Ej: 1234/2026">
                        </div>

                        <div class="d-flex justify-content-between">
                            <a href="/loteos/{{loteo.idLoteo}}/lotes" class="btn btn-secondary">Cancelar</a>
                            <button type="submit" class="btn btn-success">Guardar Etapa</button>
                        </div>

                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

</body>
</html>