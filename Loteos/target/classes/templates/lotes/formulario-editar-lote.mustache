<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Editar Lote</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card shadow">
                    <div class="card-header bg-warning text-dark">
                        <h4 class="mb-0">Modificar Datos - Cuenta: {{lote.numeroCuenta}}</h4>
                    </div>
                    <div class="card-body">
                        <form action="/lotes/{{lote.idLote}}/editar" method="post">
                            
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label for="numeroCuenta" class="form-label fw-bold">Número de Cuenta</label>
                                    <input type="text" class="form-control" id="numeroCuenta" name="numeroCuenta" value="{{lote.numeroCuenta}}" 
                                           required pattern="\d{12}" maxlength="12" minlength="12" 
                                           title="La cuenta debe tener exactamente 12 números">
                                </div>
                                <div class="col-md-6">
                                    <label for="nomenclatura" class="form-label fw-bold">Nomenclatura</label>
                                    <input type="text" class="form-control" id="nomenclatura" name="nomenclatura" value="{{lote.nomenclatura}}"
                                           required pattern="\d{16}" maxlength="16" minlength="16" 
                                           title="La nomenclatura debe tener exactamente 16 números">
                                </div>
                            </div>
                            
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label for="titular" class="form-label fw-bold">Titular / Propietario</label>
                                    <input type="text" class="form-control" id="titular" name="titular" value="{{lote.titular}}">
                                </div>
                                <div class="col-md-6">
                                    <label for="designacionOficial" class="form-label fw-bold">Designación Oficial</label>
                                    <input type="text" class="form-control" id="designacionOficial" name="designacionOficial" value="{{lote.designacionOficial}}">
                                </div>
                            </div>
                            
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label for="superficie" class="form-label fw-bold">Superficie Total (m²)</label>
                                    <input type="number" step="0.01" class="form-control" id="superficie" name="superficie" value="{{lote.superficie}}">
                                </div>
                                <div class="col-md-6">
                                    <label for="superficieCubierta" class="form-label fw-bold">Superficie Cubierta (m²)</label>
                                    <input type="number" step="0.01" class="form-control" id="superficieCubierta" name="superficieCubierta" value="{{lote.superficieCubierta}}">
                                </div>
                            </div>

                            <div class="row mb-4">
                                <div class="col-md-8">
                                    <label for="observaciones" class="form-label fw-bold">Observaciones</label>
                                    <textarea class="form-control" id="observaciones" name="observaciones" rows="1">{{lote.observaciones}}</textarea>
                                </div>
                            </div>

                            <div class="d-flex justify-content-between">
                                <a href="/loteos/{{lote.loteo.idLoteo}}/lotes" class="btn btn-outline-secondary">Cancelar</a>
                                <button type="submit" class="btn btn-warning fw-bold">Guardar Cambios</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.getElementById('estado').value = '{{lote.estado}}';
    </script>
</body>
</html>