<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Lotes del Proyecto</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <nav class="navbar navbar-dark bg-dark mb-4">
        <div class="container-fluid px-4 d-flex justify-content-between">
            <span class="navbar-brand mb-0 h1">Sistema de Gestión Parcelaria</span>
            
            <div class="d-flex gap-2">
                <a href="/loteos" class="btn btn-outline-light btn-sm">Volver a Loteos</a>
                
                <form action="/logout" method="post" class="m-0">
                    <button type="submit" class="btn btn-outline-danger btn-sm">Cerrar Sesión</button>
                </form>
            </div>
        </div>
    </nav>

    <div class="container-fluid px-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <div class="d-flex align-items-center gap-3 mb-1">
                    <h2 class="text-primary m-0">{{loteo.nombre}}</h2>
                    <a href="/loteos/{{loteo.idLoteo}}/editar" class="btn btn-outline-warning btn-sm">✏️ Editar Nombre</a>
                    <form action="/loteos/{{loteo.idLoteo}}/eliminar" method="post" class="m-0" onsubmit="return confirm('ATENCIÓN: Borrar este proyecto eliminará TODAS las parcelas. ¿Estás seguro?');">
                        <button type="submit" class="btn btn-outline-danger btn-sm">🗑️ Eliminar Loteo</button>
                    </form>
                </div>
                <p class="text-muted m-0">Gestión de parcelas y cuentas</p>
            </div>
            <div class ="d-flex justify-content-end gap-2 mb-3">
                <a href="/loteos/{{loteo.idLoteo}}/etapas/nueva" class="btn btn-secondary fw-bold">+ Nueva Etapa</a>
                <a href="/loteos/{{loteo.idLoteo}}/lotes/nuevo" class="btn btn-success fw-bold">+ Nuevo Lote</a>
                
                {{#tieneEtapas}}
                    {{#etapaSeleccionada}}
                        <a href="/loteos/{{loteo.idLoteo}}/visor?idEtapa={{etapaSeleccionada}}" class="btn btn-info text-white fw-bold">
                            🗺️ Ver Plano
                        </a>
                    {{/etapaSeleccionada}}
                {{/tieneEtapas}}

                {{^tieneEtapas}}
                    <a href="/loteos/{{loteo.idLoteo}}/visor" class="btn btn-info text-white fw-bold">
                        🗺️ Ver Plano
                    </a>
                {{/tieneEtapas}}
            </div>
        </div>

        <div class="row">
            <div class="row justify-content-center">
            
            <div class="{{#loteSeleccionado}}col-md-4{{/loteSeleccionado}}{{^loteSeleccionado}}col-md-8{{/loteSeleccionado}} transition-all">
                
                {{#tieneEtapas}}
                    <ul class="nav nav-tabs mb-3">
                        {{#etapas}}
                            <li class="nav-item">
                                <a class="nav-link fw-bold" href="/loteos/{{loteo.idLoteo}}/lotes?idEtapa={{idEtapa}}">📁 {{nombre}}</a>
                            </li>
                        {{/etapas}}
                    </ul>
                {{/tieneEtapas}}

                <form action="/loteos/{{loteo.idLoteo}}/lotes" method="get" class="mb-3">
                    <div class="input-group shadow-sm">
                        {{#etapaSeleccionada}}
                            <input type="hidden" name="idEtapa" value="{{etapaSeleccionada}}">
                        {{/etapaSeleccionada}}
                        <input type="text" name="buscar" class="form-control" placeholder="Buscar cuenta o titular..." value="{{#buscar}}{{buscar}}{{/buscar}}">
                        <button class="btn btn-primary" type="submit">🔍</button>
                        {{#buscar}}
                            <a href="/loteos/{{loteo.idLoteo}}/lotes{{#etapaSeleccionada}}?idEtapa={{etapaSeleccionada}}{{/etapaSeleccionada}}" class="btn btn-outline-secondary">X</a>
                        {{/buscar}}
                    </div>
                </form>

                <div class="list-group shadow-sm" style="max-height: 65vh; overflow-y: auto;">
                    {{#lotes}}
                    <a href="/loteos/{{loteo.idLoteo}}/lotes?idLoteSeleccionado={{idLote}}{{#etapaSeleccionada}}&idEtapa={{etapaSeleccionada}}{{/etapaSeleccionada}}{{#buscar}}&buscar={{buscar}}{{/buscar}}" 
                        class="list-group-item list-group-item-action py-2">
                        <div class="d-flex justify-content-between align-items-center">
                            <strong class="text-dark">Nro Cuenta: {{numeroCuenta}}</strong>
                        </div>
                        <small class="text-muted d-block text-truncate">Titular: {{#titular}}{{titular}}{{/titular}}{{^titular}}Sin asignar{{/titular}}</small>
                    </a>
                    {{/lotes}}
                    
                    {{^lotes}}
                    <div class="alert alert-warning p-2 text-center text-muted small m-0">
                        No se encontraron parcelas.
                    </div>
                    {{/lotes}}
                </div>
            </div>

            {{#loteSeleccionado}}
            <div class="col-md-8">
                <div class="card shadow">
                    <div class="card-body fs-6">
                        <div class="row mb-2">
                            <div class="col-sm-4 text-muted fw-bold">N° de Cuenta:</div>
                            <div class="col-sm-8 fs-5 text-dark fw-bold">{{numeroCuenta}}</div>
                        </div>
                        <hr class="my-2">
                        <div class="row mb-2">
                            <div class="col-sm-4 text-muted fw-bold">Nomenclatura:</div>
                            <div class="col-sm-8">{{#nomenclatura}}{{nomenclatura}}{{/nomenclatura}}{{^nomenclatura}}<span class="text-muted fst-italic">No cargada</span>{{/nomenclatura}}</div>
                        </div>
                        <hr class="my-2">
                        <div class="row mb-2">
                            <div class="col-sm-4 text-muted fw-bold">Titular:</div>
                            <div class="col-sm-8">{{#titular}}{{titular}}{{/titular}}{{^titular}}<span class="text-muted fst-italic">Sin asignar</span>{{/titular}}</div>
                        </div>
                        <hr class="my-2">
                        <div class="row mb-2">
                            <div class="col-sm-4 text-muted fw-bold">Designación Oficial:</div>
                            <div class="col-sm-8">{{#designacionOficial}}{{designacionOficial}}{{/designacionOficial}}{{^designacionOficial}}<span class="text-muted fst-italic">-</span>{{/designacionOficial}}</div>
                        </div>
                        <hr class="my-2">
                        <div class="row mb-2">
                            <div class="col-sm-4 text-muted fw-bold">Superficies (m²):</div>
                            <div class="col-sm-8">
                                <strong>Total:</strong> {{#superficie}}{{superficie}}{{/superficie}}{{^superficie}}0{{/superficie}} <br>
                                <strong>Cubierta:</strong> {{#superficieCubierta}}{{superficieCubierta}}{{/superficieCubierta}}{{^superficieCubierta}}0{{/superficieCubierta}}
                            </div>
                        </div>
                        <hr class="my-2">
                        <div class="row mb-2">
                            <div class="col-sm-4 text-muted fw-bold">Cuenta EMOS:</div>
                            <div class="col-sm-8">{{#cuentaEmos}}{{cuentaEmos}}{{/cuentaEmos}}{{^cuentaEmos}}<span class="text-muted fst-italic">0</span>{{/cuentaEmos}}</div>
                        </div>
                        <div class="row mb-2">
                            <div class="col-sm-4 text-muted fw-bold">Cuenta Municipal:</div>    
                            <div class="col-sm-8">{{#cuentaMuni}}{{cuentaMuni}}{{/cuentaMuni}}{{^cuentaMuni}}<span class="text-muted fst-italic">0</span>{{/cuentaMuni}}</div>   
                        </div>
                        <hr class="my-2">
                        <div class="row mb-2">
                            <div class="col-sm-4 text-muted fw-bold">Observaciones:</div>
                            <div class="col-sm-8">{{#observaciones}}{{observaciones}}{{/observaciones}}{{^observaciones}}<span class="text-muted fst-italic">Ninguna</span>{{/observaciones}}</div>
                        </div>
                    </div>
                    
                    <div class="card-footer text-end bg-white d-flex justify-content-end gap-2 p-3">
                        <a href="/loteos/{{loteo.idLoteo}}/visor?cuenta={{numeroCuenta}}{{#etapaSeleccionada}}&idEtapa={{etapaSeleccionada}}{{/etapaSeleccionada}}" class="btn btn-info text-white fw-bold">🗺️ Mostrar en Plano</a>
                        <a href="/lotes/{{idLote}}/editar" class="btn btn-warning fw-bold">Modificar Datos</a>
                        <form action="/lotes/{{idLote}}/eliminar" method="post" class="m-0" onsubmit="return confirm('¿Estás seguro de que querés borrar esta parcela definitivamente?');">
                            <button type="submit" class="btn btn-danger fw-bold">Eliminar Parcela</button>
                        </form>
                    </div>
                </div>
            </div>
            {{/loteSeleccionado}}

            {{^loteSeleccionado}}
            <div class="col-md-8">
                <div class="card border-1 border-dashed shadow-none h-100 d-flex align-items-center justify-content-center bg-transparent" style="min-height: 400px;">
                    <div class="text-center text-muted">
                        <h1 class="display-3 opacity-25">📋</h1>
                        <h5>Seleccioná una cuenta de la lista</h5>
                        <p>Los detalles de la parcela aparecerán acá.</p>
                    </div>
                </div>
            </div>
            {{/loteSeleccionado}}

        </div>
    </div>

</body>
</html>