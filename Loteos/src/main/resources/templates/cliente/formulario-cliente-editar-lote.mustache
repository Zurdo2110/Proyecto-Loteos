<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Editar Lote</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card shadow">
                    <div class="card-header bg-warning text-dark">
                        <h4 class="mb-0">Modificar Datos - Cuenta: {{lote.numeroCuenta}}</h4>
                    </div>
                    <div class="card-body">
                        <form action="/cliente/lotes/{{lote.idLote}}/editar" method="post">
                            {{#etapaSeleccionada}}
                            <input type="hidden" name="idEtapa" value="{{etapaSeleccionada}}">
                            {{/etapaSeleccionada}}
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label for="titular" class="form-label fw-bold">Titular / Propietario</label>
                                    <input type="text" class="form-control" id="titular" name="titular" value="{{lote.titular}}">
                                </div>
                                <div class="col-md-6">
                                    <label for="designacionOficial" class="form-label fw-bold">Designación Oficial</label>
                                    <input type="text" class="form-control" id="designacionOficial" name="designacionOficial" value="{{lote.designacionOficial}}">
                                </div>
                                <div class="col-md-6">
                                    <label for="cuentaEmos" class="form-label fw-bold">Cuenta EMOS</label>
                                    <input type="number" class="form-control" id="cuentaEmos" name="cuentaEmos" value="{{lote.cuentaEmos}}">
                                </div>
                                <div class="col-md-6">  
                                    <label for="cuentaMuni" class="form-label fw-bold">Cuenta Municipal</label>
                                    <input type="number" class="form-control" id="cuentaMuni" name="cuentaMuni" value="{{lote.cuentaMuni}}">       \
                                </div>
                            </div>

                            <div class="row mb-4">
                                <div class="col-md-8">
                                    <label for="observaciones" class="form-label fw-bold">Observaciones</label>
                                    <textarea class="form-control" id="observaciones" name="observaciones" rows="1">{{lote.observaciones}}</textarea>
                                </div>
                            </div>

                            <div class="d-flex justify-content-between">
                                <a href="/cliente/loteos/{{lote.loteo.idLoteo}}/lotes{{#etapaSeleccionada}}?idEtapa={{etapaSeleccionada}}{{/etapaSeleccionada}}" class="btn btn-outline-secondary">Cancelar</a>
                                <button type="submit" class="btn btn-warning fw-bold">Guardar Cambios</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

</body>
</html>